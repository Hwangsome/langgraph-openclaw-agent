# If set, the agent will use a real OpenAI-compatible model via langchain-openai.
# If NOT set, the agent runs in MOCK mode (rule-based) but still demonstrates tool calling.
OPENAI_API_KEY=

# Optional: override base URL/model.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Safety limits for read_file tool
OC_LG_AGENT_ALLOWED_ROOT=.
OC_LG_AGENT_MAX_BYTES=65536
